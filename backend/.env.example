# Server Configuration
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/astrology-platform
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL (used for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Cloudinary Config (Optional — falls back to local uploads if empty)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI Config (Optional — falls back to mock Whisper transcripts if empty)
OPENAI_API_KEY=sk-your-openai-api-key

# Gemini Config (Optional — falls back to mock astrological insights if empty)
GEMINI_API_KEY=your-gemini-api-key

# Nodemailer / SMTP Config (Optional — falls back to console logging if empty)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=no-reply@tumharapandit.com
